<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.user.ReportFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Report Violation"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- File Upload -->
        <LinearLayout
            android:id="@+id/selectFileLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"

            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/titleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/takePhotoLayout"
            app:layout_constraintWidth_percent="0.45"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="8dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/submit1" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="select file"
                android:textColor="#F4A536"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Camera -->
        <LinearLayout
            android:id="@+id/takePhotoLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"

            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/titleText"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/selectFileLayout"
            app:layout_constraintWidth_percent="0.45"
            android:layout_marginTop="24dp"
            android:layout_marginStart="8dp">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/takephoto" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="take photo"
                android:textColor="#F4A536"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- GPS Location -->
        <EditText
            android:id="@+id/locationInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Location [Auto GPS address]"

            android:padding="12dp"
            android:textColorHint="#000"
            app:layout_constraintTop_toBottomOf="@id/selectFileLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp"/>

        <!-- Date -->
        <EditText
            android:id="@+id/dateInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Date: dd/mm/yyyy"

            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/locationInput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"/>

        <!-- Plate Number  -->
        <EditText
            android:id="@+id/carPlateInput1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Text: Car Plate Number"

            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/dateInput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"/>

        <!-- Confirm Plate Number  -->
        <EditText
            android:id="@+id/carPlateInput2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Text: Car Plate Number"

            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/carPlateInput1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"/>

        <!-- Confirm Checkbox -->
        <CheckBox
            android:id="@+id/confirmCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I confirm the information is true and accurate."
            app:layout_constraintTop_toBottomOf="@id/carPlateInput2"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="16dp"/>

        <!-- Submit Button -->
        <Button
            android:id="@+id/submitButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@color/black"
            android:text="Submit"
            android:textColor="#FFFFFF"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/confirmCheckbox" />

        <!-- Home Button -->

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
