<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.admin.fragment.unreview.Unreview_list_deatilActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Report Review"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- MapView -->
        <com.google.android.gms.maps.MapView
            android:id="@+id/mapView2"
            android:layout_width="362dp"
            android:layout_height="153dp"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@+id/title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Info Summary -->
        <TextView
            android:id="@+id/infoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="15dp"
            android:text="Info Summary:"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/mapView2" />

        <!-- Car Plate -->
        <TextView
            android:id="@+id/labelCarPlate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:text="Car Plate:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/infoLabel" />

        <TextView
            android:id="@+id/valueCarPlate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ABC123"
            android:layout_marginStart="8dp"
            app:layout_constraintBaseline_toBaselineOf="@id/labelCarPlate"
            app:layout_constraintStart_toEndOf="@id/labelCarPlate" />

        <!-- Location -->
        <TextView
            android:id="@+id/labelLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:text="Location:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelCarPlate" />

        <TextView
            android:id="@+id/valueLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="123 Main St"
            android:layout_marginStart="8dp"
            app:layout_constraintBaseline_toBaselineOf="@id/labelLocation"
            app:layout_constraintStart_toEndOf="@id/labelLocation" />

        <!-- Time -->
        <TextView
            android:id="@+id/labelTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:text="Time:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelLocation" />

        <TextView
            android:id="@+id/valueTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2025-04-11 14:32"
            android:layout_marginStart="8dp"
            app:layout_constraintBaseline_toBaselineOf="@id/labelTime"
            app:layout_constraintStart_toEndOf="@id/labelTime" />

        <!-- Notes -->
        <TextView
            android:id="@+id/labelNotes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="12dp"
            android:text="Notes:"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelTime" />

        <TextView
            android:id="@+id/valueNotes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Blocked pedestrian path"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="@id/labelNotes"
            app:layout_constraintStart_toEndOf="@id/labelNotes"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Review Outcome Section -->
        <TextView
            android:id="@+id/reviewSection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:text="Review Outcome Section:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/valueNotes" />

        <!-- Status -->
        <TextView
            android:id="@+id/labelStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:text="Status:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/reviewSection" />

        <TextView
            android:id="@+id/valueStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:layout_marginStart="8dp"
            app:layout_constraintBaseline_toBaselineOf="@id/labelStatus"
            app:layout_constraintStart_toEndOf="@id/labelStatus" />

        <!-- Feedback -->
        <TextView
            android:id="@+id/labelFeedback"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:text="Feedback:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelStatus" />

        <TextView
            android:id="@+id/valueFeedback"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Violation confirmed by officer."
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="@id/labelFeedback"
            app:layout_constraintStart_toEndOf="@id/labelFeedback"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Points -->
        <TextView
            android:id="@+id/labelPoints"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:text="Points Earned:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelFeedback" />

        <TextView
            android:id="@+id/valuePoints"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+20"
            android:layout_marginStart="8dp"
            app:layout_constraintBaseline_toBaselineOf="@id/labelPoints"
            app:layout_constraintStart_toEndOf="@id/labelPoints" />

        <!-- Radio Group -->
        <RadioGroup
            android:id="@+id/radioGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/labelPoints"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <RadioButton
                android:id="@+id/approveButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Approve" />

            <RadioButton
                android:id="@+id/rejectButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reject"
                android:layout_marginStart="32dp" />
        </RadioGroup>

        <!-- Message -->
        <EditText
            android:id="@+id/messageField"
            android:layout_width="0dp"
            android:layout_height="69dp"
            android:layout_marginTop="15dp"
            android:gravity="top"
            android:hint="  Leave Message: This is a text field"
            android:padding="12dp"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/radioGroup"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Submit Button -->
        <Button
            android:id="@+id/submitButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="15dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/button_login_background"
            android:text="Submit"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/messageField"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
