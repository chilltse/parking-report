<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 标题 -->
        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Report Detail"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 地图 -->
        <com.google.android.gms.maps.MapView
            android:id="@+id/mapView"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 信息小标题 -->
        <TextView
            android:id="@+id/infoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Info Summary:"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/mapView"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- 分隔线 -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="#CCCCCC"
            app:layout_constraintTop_toBottomOf="@id/infoLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Car Plate -->
        <TextView
            android:id="@+id/labelCarPlate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Car Plate:"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/infoLabel"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/valueCarPlate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="16dp"
            android:text="ABC123"
            android:textSize="16sp"
            app:layout_constraintBaseline_toBaselineOf="@id/labelCarPlate"
            app:layout_constraintStart_toEndOf="@id/labelCarPlate"/>

        <!-- Location -->
        <TextView
            android:id="@+id/labelLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Location:"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/labelCarPlate"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/valueLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="12dp"
            android:text="123 Main St"
            android:textSize="16sp"
            app:layout_constraintBaseline_toBaselineOf="@id/labelLocation"
            app:layout_constraintStart_toEndOf="@id/labelLocation"/>

        <!-- Time -->
        <TextView
            android:id="@+id/labelTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Time:"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/labelLocation"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/valueTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="12dp"
            android:text="2025-04-11 14:32"
            android:textSize="16sp"
            app:layout_constraintBaseline_toBaselineOf="@id/labelTime"
            app:layout_constraintStart_toEndOf="@id/labelTime"/>

        <!-- Notes -->
        <TextView
            android:id="@+id/labelNotes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Notes:"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/valueTime"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/valueNotes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Blocked pedestrian path"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/labelNotes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Review Outcome -->
        <TextView
            android:id="@+id/reviewOutcomeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Review Outcome:"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/valueNotes"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Status -->
        <TextView
            android:id="@+id/labelStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Status:"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/reviewOutcomeLabel"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/valueStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="12dp"
            android:text="✅ Approved"
            android:textSize="16sp"
            app:layout_constraintBaseline_toBaselineOf="@id/labelStatus"
            app:layout_constraintStart_toEndOf="@id/labelStatus"/>

        <!-- Feedback -->
        <TextView
            android:id="@+id/labelFeedback"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Feedback:"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/labelStatus"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/valueFeedback"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Violation confirmed by officer."
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/labelFeedback"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Points -->
        <TextView
            android:id="@+id/labelPoints"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Points Earned:"
            android:textSize="18sp"
            app:layout_constraintTop_toBottomOf="@id/valueFeedback"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/valuePoints"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="24dp"
            android:text="+20"
            android:textSize="16sp"
            app:layout_constraintBaseline_toBaselineOf="@id/labelPoints"
            app:layout_constraintStart_toEndOf="@id/labelPoints"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
