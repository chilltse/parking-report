<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Report Detail"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 地图 -->
        <com.google.android.gms.maps.MapView
            android:id="@+id/mapView"
            android:layout_width="289dp"
            android:layout_height="287dp"
            android:layout_marginTop="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title" />

        <!-- 信息小标题 -->
        <TextView
            android:id="@+id/infoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Info Summary:"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/mapView" />

        <!-- Car Plate -->
        <TextView
            android:id="@+id/labelCarPlate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Car Plate:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/infoLabel" />

        <TextView
            android:id="@+id/valueCarPlate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="ABC123"
            app:layout_constraintStart_toEndOf="@id/labelCarPlate"
            app:layout_constraintTop_toTopOf="@id/labelCarPlate" />

        <!-- Location -->
        <TextView
            android:id="@+id/labelLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Location:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelCarPlate" />

        <TextView
            android:id="@+id/valueLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="123 Main St"
            app:layout_constraintStart_toEndOf="@id/labelLocation"
            app:layout_constraintTop_toTopOf="@id/labelLocation" />

        <!-- Time -->
        <TextView
            android:id="@+id/labelTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelLocation" />

        <TextView
            android:id="@+id/valueTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="2025-04-11 14:32"
            app:layout_constraintStart_toEndOf="@id/labelTime"
            app:layout_constraintTop_toTopOf="@id/labelTime" />

        <!-- Notes -->
        <TextView
            android:id="@+id/labelNotes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Notes:"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelTime" />

        <TextView
            android:id="@+id/valueNotes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Blocked pedestrian path"
            app:layout_constraintStart_toEndOf="@id/labelNotes"
            app:layout_constraintTop_toTopOf="@id/labelNotes" />

        <!-- Review Outcome -->
        <TextView
            android:id="@+id/reviewOutcomeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Review Outcome Section:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelNotes" />

        <!-- Status -->
        <TextView
            android:id="@+id/labelStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/reviewOutcomeLabel" />

        <TextView
            android:id="@+id/valueStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="✅ Approved"
            app:layout_constraintStart_toEndOf="@id/labelStatus"
            app:layout_constraintTop_toTopOf="@id/labelStatus" />

        <!-- Feedback -->
        <TextView
            android:id="@+id/labelFeedback"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Feedback:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelStatus" />

        <TextView
            android:id="@+id/valueFeedback"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Violation confirmed by officer."
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/labelFeedback"
            app:layout_constraintTop_toTopOf="@id/labelFeedback" />

        <!-- Points -->
        <TextView
            android:id="@+id/labelPoints"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Points Earned:"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelFeedback" />

        <TextView
            android:id="@+id/valuePoints"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="+20"
            app:layout_constraintStart_toEndOf="@id/labelPoints"
            app:layout_constraintTop_toTopOf="@id/labelPoints" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>

